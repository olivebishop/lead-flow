# Local SQLite (never committed to GitHub)
DATABASE_URL="file:./dev.db"

# Turso — copy from Vercel after connecting Turso integration
# Used locally only when running: pnpm db:sync
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="your-turso-token"

# Resend — https://resend.com
RESEND_API_KEY="re_xxxx"
REMINDER_EMAIL="you@example.com"
EMAIL_FROM="LeadFlow <onboarding@resend.dev>"

# Protect the reminders API route
CRON_SECRET="your-random-secret"

# ── How data reaches production (without GitHub) ───────────────────────────
#
# 1. prisma/dev.db is gitignored — your leads never go on public GitHub
# 2. Connect Turso in Vercel → Integrations → Turso (sets TURSO_* on Vercel)
# 3. Copy TURSO_DATABASE_URL + TURSO_AUTH_TOKEN into local .env
# 4. Run: pnpm db:sync
#    → pushes schema + copies all local leads to Turso
# 5. Redeploy Vercel — production reads from Turso, not a local file
