DATABASE_URL="file:./dev.db"

# Resend — https://resend.com
RESEND_API_KEY="re_xxxx"
REMINDER_EMAIL="you@example.com"
EMAIL_FROM="LeadFlow <onboarding@resend.dev>"

# Protect the reminders API route (required when hosted online)
CRON_SECRET="your-random-secret"

# ── Reminders ──────────────────────────────────────────────────────────────
#
# LOCAL — run manually or schedule daily:
#   pnpm reminders:send
#
# VERCEL (online) — two options (use both for reliability):
#
#   1. GitHub Actions (recommended — works even if you forget to open the site)
#      Add these secrets in GitHub → Settings → Secrets → Actions:
#        REMINDER_URL  = https://your-app.vercel.app/api/cron/followup-reminders
#        CRON_SECRET   = same value as in Vercel env vars
#      Workflow: .github/workflows/followup-reminders.yml (runs daily 6 AM UTC)
#
#   2. Opening the site — also sends reminders as a backup
#
# Vercel env vars: RESEND_API_KEY, REMINDER_EMAIL, EMAIL_FROM, CRON_SECRET, DATABASE_URL
# Note: SQLite files don't persist on Vercel — use Turso or Postgres for production.
